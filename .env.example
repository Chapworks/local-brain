# =============================================================================
# Local Brain Configuration
# =============================================================================

# Database
DB_PASSWORD=change-me-to-a-strong-random-password

# MCP Authentication
MCP_ACCESS_KEY=change-me-to-a-long-random-string

# Cloudflare Tunnel (for home hosting — see CLOUDFLARE-TUNNEL.md)
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token

# =============================================================================
# Admin Panel
#
# The admin UI is a web dashboard for viewing thoughts, editing config,
# viewing logs, and restarting services.
#
# ADMIN_JWT_SECRET — used to sign session cookies. Generate one:
#   openssl rand -base64 32
#
# ADMIN_ACCESS_MODE — "local" (default) only allows access via localhost.
#   Set to "remote" to allow access through the Cloudflare Tunnel.
# =============================================================================
ADMIN_JWT_SECRET=change-me-generate-with-openssl-rand
ADMIN_ACCESS_MODE=local

# =============================================================================
# AI Provider Configuration
#
# Local Brain needs two AI services:
#   1. Embeddings — converts text to vectors for semantic search
#   2. Chat — extracts metadata (topics, people, action items) from thoughts
#
# You can use the same provider for both, or mix and match.
# Pick ONE option below and uncomment it. Comment out the others.
# =============================================================================

# -----------------------------------------------------------------------------
# OPTION A: OpenRouter (simplest — one key, access to many models)
#
# Sign up at https://openrouter.ai — ~$5 in credits lasts months
# -----------------------------------------------------------------------------
EMBEDDING_API_BASE=https://openrouter.ai/api/v1
EMBEDDING_API_KEY=your-openrouter-api-key
EMBEDDING_MODEL=openai/text-embedding-3-small
CHAT_API_BASE=https://openrouter.ai/api/v1
CHAT_API_KEY=your-openrouter-api-key
CHAT_MODEL=openai/gpt-4o-mini
CHAT_API_FORMAT=openai

# -----------------------------------------------------------------------------
# OPTION B: OpenAI direct (no middleman)
#
# Sign up at https://platform.openai.com
# -----------------------------------------------------------------------------
# EMBEDDING_API_BASE=https://api.openai.com/v1
# EMBEDDING_API_KEY=sk-your-openai-key
# EMBEDDING_MODEL=text-embedding-3-small
# CHAT_API_BASE=https://api.openai.com/v1
# CHAT_API_KEY=sk-your-openai-key
# CHAT_MODEL=gpt-4o-mini
# CHAT_API_FORMAT=openai

# -----------------------------------------------------------------------------
# OPTION C: OpenAI for embeddings + Claude for metadata extraction
#
# Best of both — cheap OpenAI embeddings, Claude for the smart work.
# Requires both an OpenAI key and an Anthropic key.
# -----------------------------------------------------------------------------
# EMBEDDING_API_BASE=https://api.openai.com/v1
# EMBEDDING_API_KEY=sk-your-openai-key
# EMBEDDING_MODEL=text-embedding-3-small
# CHAT_API_BASE=https://api.anthropic.com/v1
# CHAT_API_KEY=sk-ant-your-anthropic-key
# CHAT_MODEL=claude-haiku-4-5-20251001
# CHAT_API_FORMAT=anthropic

# -----------------------------------------------------------------------------
# OPTION D: OpenRouter for embeddings + Claude for metadata extraction
#
# Like Option C but uses OpenRouter for embeddings instead of OpenAI direct.
# -----------------------------------------------------------------------------
# EMBEDDING_API_BASE=https://openrouter.ai/api/v1
# EMBEDDING_API_KEY=your-openrouter-api-key
# EMBEDDING_MODEL=openai/text-embedding-3-small
# CHAT_API_BASE=https://api.anthropic.com/v1
# CHAT_API_KEY=sk-ant-your-anthropic-key
# CHAT_MODEL=claude-haiku-4-5-20251001
# CHAT_API_FORMAT=anthropic
