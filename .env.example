# =============================================================================
# Local Brain Configuration
# =============================================================================

# Database
DB_PASSWORD=change-me-to-a-strong-random-password

# MCP Authentication
MCP_ACCESS_KEY=change-me-to-a-long-random-string

# Cloudflare Tunnel (for home hosting — see CLOUDFLARE-TUNNEL.md)
# Skip this if using cloud hosting with Caddy.
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token

# Domain (for cloud hosting with Caddy — see CLOUD-HOSTING.md)
# Skip this if using Cloudflare Tunnel.
# DOMAIN=brain.yourdomain.com

# =============================================================================
# Admin Panel
#
# The admin UI is a web dashboard for viewing thoughts, editing config,
# viewing logs, and restarting services.
#
# ADMIN_JWT_SECRET — used to sign session cookies. Generate one:
#   openssl rand -base64 32
#
# ADMIN_ACCESS_MODE — "local" (default) only allows access via localhost.
#   Set to "remote" to allow access through the Cloudflare Tunnel.
# =============================================================================
ADMIN_JWT_SECRET=change-me-generate-with-openssl-rand
ADMIN_ACCESS_MODE=local

# =============================================================================
# Database Backups
#
# Automated pg_dump backups run on a cron schedule inside a dedicated container.
# Backups are gzip-compressed and stored in a Docker volume.
# Optionally encrypted and uploaded to cloud storage.
#
# See BACKUPS.md for full setup guide, cloud provider examples, and restore
# instructions.
#
# BACKUP_CRON — cron schedule (default: 3 AM daily)
# BACKUP_RETAIN_COUNT — local backups to keep (default: 7)
# BACKUP_ENCRYPTION_KEY — encrypt backups with AES-256 (optional, recommended)
# =============================================================================
# BACKUP_CRON=0 3 * * *
# BACKUP_RETAIN_COUNT=7
# BACKUP_ENCRYPTION_KEY=generate-with-openssl-rand-base64-32

# -----------------------------------------------------------------------------
# Cloud Backup (optional) — uses rclone to sync backups off-site
#
# Set RCLONE_REMOTE to enable. The RCLONE_CONFIG_REMOTE_* variables configure
# the rclone remote entirely via environment (no rclone.conf file needed).
#
# RCLONE_REMOTE — "remote:bucket/path" (enables cloud upload when set)
# BACKUP_CLOUD_RETAIN_COUNT — cloud backups to keep (default: 30)
#
# Pick ONE provider below. See BACKUPS.md for more options.
# -----------------------------------------------------------------------------

# --- Backblaze B2 (cheapest — $0.005/GB/month, 10GB free) ---
# RCLONE_REMOTE=remote:your-bucket-name/local-brain
# RCLONE_CONFIG_REMOTE_TYPE=s3
# RCLONE_CONFIG_REMOTE_PROVIDER=Other
# RCLONE_CONFIG_REMOTE_ACCESS_KEY_ID=your-b2-key-id
# RCLONE_CONFIG_REMOTE_SECRET_ACCESS_KEY=your-b2-application-key
# RCLONE_CONFIG_REMOTE_ENDPOINT=s3.us-west-004.backblazeb2.com
# RCLONE_CONFIG_REMOTE_REGION=us-west-004

# --- Cloudflare R2 (no egress fees — 10GB free) ---
# RCLONE_REMOTE=remote:your-bucket-name/local-brain
# RCLONE_CONFIG_REMOTE_TYPE=s3
# RCLONE_CONFIG_REMOTE_PROVIDER=Cloudflare
# RCLONE_CONFIG_REMOTE_ACCESS_KEY_ID=your-r2-access-key
# RCLONE_CONFIG_REMOTE_SECRET_ACCESS_KEY=your-r2-secret-key
# RCLONE_CONFIG_REMOTE_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# --- AWS S3 ---
# RCLONE_REMOTE=remote:your-bucket-name/local-brain
# RCLONE_CONFIG_REMOTE_TYPE=s3
# RCLONE_CONFIG_REMOTE_PROVIDER=AWS
# RCLONE_CONFIG_REMOTE_ACCESS_KEY_ID=your-aws-access-key
# RCLONE_CONFIG_REMOTE_SECRET_ACCESS_KEY=your-aws-secret-key
# RCLONE_CONFIG_REMOTE_REGION=us-east-1

# =============================================================================
# Digests
#
# Scheduled thought summaries delivered via webhook (Slack, Discord, etc.)
# Configure digest recipients in the admin panel.
# =============================================================================
# DIGEST_TIMEZONE=America/New_York

# =============================================================================
# AI Provider Configuration
#
# Local Brain needs two AI services:
#   1. Embeddings — converts text to vectors for semantic search
#   2. Chat — extracts metadata (topics, people, action items) from thoughts
#
# You can use the same provider for both, or mix and match.
# Pick ONE option below and uncomment it. Comment out the others.
# =============================================================================

# -----------------------------------------------------------------------------
# OPTION A: OpenRouter (simplest — one key, access to many models)
#
# Sign up at https://openrouter.ai — ~$5 in credits lasts months
# -----------------------------------------------------------------------------
EMBEDDING_API_BASE=https://openrouter.ai/api/v1
EMBEDDING_API_KEY=your-openrouter-api-key
EMBEDDING_MODEL=openai/text-embedding-3-small
CHAT_API_BASE=https://openrouter.ai/api/v1
CHAT_API_KEY=your-openrouter-api-key
CHAT_MODEL=openai/gpt-4o-mini
CHAT_API_FORMAT=openai

# -----------------------------------------------------------------------------
# OPTION B: OpenAI direct (no middleman)
#
# Sign up at https://platform.openai.com
# -----------------------------------------------------------------------------
# EMBEDDING_API_BASE=https://api.openai.com/v1
# EMBEDDING_API_KEY=sk-your-openai-key
# EMBEDDING_MODEL=text-embedding-3-small
# CHAT_API_BASE=https://api.openai.com/v1
# CHAT_API_KEY=sk-your-openai-key
# CHAT_MODEL=gpt-4o-mini
# CHAT_API_FORMAT=openai

# -----------------------------------------------------------------------------
# OPTION C: OpenAI for embeddings + Claude for metadata extraction
#
# Best of both — cheap OpenAI embeddings, Claude for the smart work.
# Requires both an OpenAI key and an Anthropic key.
# -----------------------------------------------------------------------------
# EMBEDDING_API_BASE=https://api.openai.com/v1
# EMBEDDING_API_KEY=sk-your-openai-key
# EMBEDDING_MODEL=text-embedding-3-small
# CHAT_API_BASE=https://api.anthropic.com/v1
# CHAT_API_KEY=sk-ant-your-anthropic-key
# CHAT_MODEL=claude-haiku-4-5-20251001
# CHAT_API_FORMAT=anthropic

# -----------------------------------------------------------------------------
# OPTION D: OpenRouter for embeddings + Claude for metadata extraction
#
# Like Option C but uses OpenRouter for embeddings instead of OpenAI direct.
# -----------------------------------------------------------------------------
# EMBEDDING_API_BASE=https://openrouter.ai/api/v1
# EMBEDDING_API_KEY=your-openrouter-api-key
# EMBEDDING_MODEL=openai/text-embedding-3-small
# CHAT_API_BASE=https://api.anthropic.com/v1
# CHAT_API_KEY=sk-ant-your-anthropic-key
# CHAT_MODEL=claude-haiku-4-5-20251001
# CHAT_API_FORMAT=anthropic
